GROQ_API_KEY=your_api_key_here
MONGO_URI=your_mongodb_connection
PORT=5000
ENABLE_KISMET=false

# Kismet single-dongle tuning
SINGLE_DONGLE_MODE=false
MIN_SIGNAL_DBM=-85
DEDUPE_WINDOW_SECONDS=8
# Optional CSV override. Example: DEAUTHFLOOD,DISASSOCFLOOD,BEACONFLOOD
KISMET_ALLOWED_ALERTS=

# Security (set to true to enforce API key authentication)
SECURITY_ENFORCE_API_KEY=false
SECURITY_API_KEY=change_me

# Frontend (client/.env): optional key sent with requests when security is enabled
# VITE_SECURITY_API_KEY=change_me