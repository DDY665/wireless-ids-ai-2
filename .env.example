GROQ_API_KEY=your_api_key_here
MONGO_URI=your_mongodb_connection
PORT=5000
ENABLE_KISMET=false

SINGLE_DONGLE_MODE=false
MIN_SIGNAL_DBM=-85
DEDUPE_WINDOW_SECONDS=8
KISMET_ALLOWED_ALERTS=

# Laptop 3 poller settings
KISMET_HOST=192.168.1.XX
KISMET_PORT=2501
KISMET_USER=admin
KISMET_PASSWORD=your-kismet-password
KISMET_WS_PATH=/alerts/alerts.ws
KISMET_WS_PATHS=/alerts/all_alerts.ws,/alerts/last-time/0/alerts.ws,/alerts/wrapped/last-time/0/alerts.ws
KISMET_WS_SECURE=false
POLL_INTERVAL=5
REQUEST_TIMEOUT_SECONDS=5
ALERT_ID_CACHE_TTL_SECONDS=86400
ALERT_ID_CACHE_MAX_SIZE=20000

# LLM provider for poller (groq)
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

SECURITY_ENFORCE_API_KEY=false
SECURITY_API_KEY=change_me

# Optional backend settings
NODE_ENV=development

# Frontend (client/.env)
VITE_API_URL=http://localhost:5000
VITE_SECURITY_API_KEY=change_me